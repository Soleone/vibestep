{
  "name": "beat-fiend",
  "private": true,
  "version": "0.1.8",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:companion": "node companion/index.js",
    "dev:all": "cross-env BEAT_FIEND_WEB_URL=http://localhost:5173 concurrently \"npm run dev:companion\" \"npm run dev\"",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "test": "node --test companion/**/*.test.js desktop/**/*.test.js && node --experimental-transform-types --test tests/**/*.test.mts",
    "preview": "vite preview",
    "desktop": "electron .",
    "companion:dist:win": "electron-builder --win nsis --x64 --publish never",
    "companion:pack": "electron-builder --dir",
    "companion:release": "node scripts/release-companion.mjs",
    "companion:release:minor": "node scripts/release-companion.mjs minor",
    "companion:release:win": "electron-builder --win nsis --x64 --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "express": "^5.2.1",
    "nanoid": "^5.1.16"
  },
  "devDependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "lucide-react": "^1.24.0",
    "oxlint": "^1.69.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "three": "^0.185.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.0"
  },
  "main": "desktop/main.js",
  "build": {
    "appId": "app.beatfiend.companion",
    "productName": "Beat Fiend Companion",
    "artifactName": "Beat-Fiend-Companion-Setup.exe",
    "asar": true,
    "files": [
      "companion/**/*",
      "desktop/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "desktop/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    },
    "publish": {
      "provider": "github",
      "owner": "Soleone",
      "repo": "beatfiend",
      "releaseType": "release"
    },
    "directories": {
      "output": "release"
    }
  },
  "description": "Local audio import companion for Beat Fiend",
  "author": "Beat Fiend contributors"
}
